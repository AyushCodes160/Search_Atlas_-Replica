# Google PageSpeed Insights API (optional - works without key but has lower quota)
# Get free key at: https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=PLACEHOLDER_PAGESPEED_KEY

# Groq API (free tier, 14,400 req/day, Llama 3.3 70B)
# Get free key at: https://console.groq.com/keys
GROQ_API_KEY=PLACEHOLDER_GROQ_KEY

# ---- Auth + Database (Phase 2) ----

# Neon Postgres (free tier). Two URLs from the Neon dashboard:
#   DATABASE_URL = pooled connection (host contains "-pooler")
#   DIRECT_URL   = direct connection (no "-pooler") — used for migrations
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DIRECT_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=PLACEHOLDER_AUTH_SECRET

# Google OAuth (console.cloud.google.com → Credentials → OAuth client ID → Web)
# Redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=PLACEHOLDER_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=PLACEHOLDER_GOOGLE_CLIENT_SECRET
